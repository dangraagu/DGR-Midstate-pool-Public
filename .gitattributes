# Pin LF on shell / systemd / env files — CRLF corrupts systemd units and a
# CRLF in a SHA-extracted line once froze a whole fleet (CSD lesson).
*.sh    text eol=lf
*.service text eol=lf
*.timer text eol=lf
*.env   text eol=lf
*.ptx   binary

# Windows launchers/installers: CRLF so cmd.exe parses labels/goto reliably.
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Normal text for the rest.
*.rs   text
*.toml text
*.md   text
